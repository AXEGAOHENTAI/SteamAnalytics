<Window x:Class="SteamAnalytics.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SteamAnalytics" Height="740" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#111317">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SteamAnalytics"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="White"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,16">
            <TextBox Width="600"
                     Height="36"
                     Padding="10,6"
                     Text="{Binding InputIdentifier, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1D2129"
                     Foreground="White"
                     BorderBrush="#2B313D"
                     VerticalContentAlignment="Center"/>

            <Button Content="Проверить"
                    Margin="12,0,0,0"
                    Width="120"
                    Height="36"
                    Command="{Binding CheckProfileCommand}"/>

            <Button Content="Войти через Steam"
                    Margin="12,0,0,0"
                    Width="170"
                    Height="36"
                    Command="{Binding SignInWithSteamCommand}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A1F27" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="Профиль" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Profile.PersonaName}" Foreground="#E5E7EB" Margin="0,16,0,0" FontSize="16"/>
                    <TextBlock Text="{Binding Profile.SteamId64}" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding Profile.ProfileUrl}" Foreground="#60A5FA" Margin="0,4,0,0" TextWrapping="Wrap"/>

                    <Separator Margin="0,12,0,12"/>

                    <TextBlock Text="Проверка банов" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Profile.BanSummary}" Foreground="#FCA5A5" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1A1F27" CornerRadius="10" Padding="12">
                <TabControl>
                    <TabItem Header="Игры">
                        <ListView ItemsSource="{Binding Profile.TopGames}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="AppId" DisplayMemberBinding="{Binding AppId}" Width="80"/>
                                    <GridViewColumn Header="Игра" DisplayMemberBinding="{Binding Name}" Width="360"/>
                                    <GridViewColumn Header="Часы" DisplayMemberBinding="{Binding Hours}" Width="100"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>

                    <TabItem Header="Друзья">
                        <ListView ItemsSource="{Binding Profile.Friends}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Ник" DisplayMemberBinding="{Binding PersonaName}" Width="280"/>
                                    <GridViewColumn Header="SteamID64" DisplayMemberBinding="{Binding SteamId64}" Width="220"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>

                    <TabItem Header="Инвентарь">
                        <ListView ItemsSource="{Binding Profile.InventoryItems}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Предмет" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                    <GridViewColumn Header="Тип" DisplayMemberBinding="{Binding Type}" Width="220"/>
                                    <GridViewColumn Header="Кол-во" DisplayMemberBinding="{Binding Amount}" Width="80"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding Status}" Margin="0,12,0,0" Foreground="#9CA3AF"/>
    </Grid>
</Window>
